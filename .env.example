# ─── Servidor ───────────────────────────────────────────
PORT=3000

# ─── Base de datos PostgreSQL ────────────────────────────
# Si usas Docker (recomendado):
DATABASE_URL=postgresql://nutrovia:nutrovia123@localhost:5432/nutrovia_db
# Si tienes PostgreSQL local nativo:
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/nutrovia_db

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_123456

# ─── Stripe (pagos) ─────────────────────────────────────
# Obtén tus claves en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
# Obtén el webhook secret con: stripe listen --forward-to localhost:3000/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Email (SMTP) ────────────────────────────────────────
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_de_aplicación
EMAIL_FROM=NutroVia <tu_email@gmail.com>

# ─── App ─────────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development
